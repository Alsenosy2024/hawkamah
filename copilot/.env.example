# Hawkama Copilot — environment. Copy to `.env` and fill in.
# The copilot also reads the repo-root .env (GEMINI_API_KEY / API_KEY), so if the
# React app's key is already set there you do not need to duplicate it here.

# --- Required: Gemini Developer API key -------------------------------------
HAWKAMA_GEMINI_API_KEY=

# --- Optional: model overrides (defaults mirror constants/models.ts) ---------
# HAWKAMA_TEXT_MODEL=gemini-3.5-flash
# HAWKAMA_TEXT_FALLBACK=gemini-2.5-flash
# HAWKAMA_GEN_MODEL=gemini-3.5-flash
# HAWKAMA_EMBED_MODEL=gemini-embedding-001

# --- Optional: embedding geometry -------------------------------------------
# 1536 fits Firestore's 2048-dim KNN ceiling and halves storage vs 3072.
# HAWKAMA_EMBED_DIM=1536
# HAWKAMA_EMBED_BATCH=32
# HAWKAMA_EMBED_CONCURRENCY=6

# --- Optional: retrieval / generation knobs ---------------------------------
# HAWKAMA_RETRIEVE_K=8
# HAWKAMA_GEN_SECTION_TOKENS=8192
# HAWKAMA_GEN_MAX_SECTIONS=40

# --- Optional: paths --------------------------------------------------------
# HAWKAMA_DATA_DIR=./data
# HAWKAMA_SKILL_PATH=../../governance_operating_model_skill.md
